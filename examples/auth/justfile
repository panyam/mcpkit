# Run the demokit walkthrough (interactive, TUI)
demo:
    go run . --tui

# Run the walkthrough in notebook mode (Bubble Tea cells)
note:
    go run . --note

# Start the unified MCP server standalone (for MCPJam, VS Code, Claude Desktop)
serve:
    go run . --serve

# Regenerate WALKTHROUGH.md from demo definitions
readme:
    go run . --doc md > WALKTHROUGH.md

# Build the binary
build:
    go build -o auth-demo .

# Run individual single-pattern servers (legacy, mostly for testing).
serve-bearer:
    go run ./bearer

serve-jwt:
    go run ./jwt

serve-scopes:
    go run ./scopes

serve-session-binding:
    go run ./session-binding

serve-public-discovery:
    go run ./public-discovery

serve-unified:
    go run ./unified

default: demo
