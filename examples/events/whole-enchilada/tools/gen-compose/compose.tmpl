# GENERATED by tools/gen-compose. DO NOT EDIT.
# Regenerate via `make gen-compose [N=<n>] [M=<m>]` (default N=1, M=1).
#
# whole-enchilada — production-shape MCP Events demo, stage 2.
#
# DNS convention (resolves inside the compose network AND from the host
# when /etc/hosts is populated via `make hosts-install`):
#
#   nginx.whole_enchilada            — frontdoor (port 80)
#   event_server.whole_enchilada     — round-robin to all event-server replicas
#   event_server_<i>.whole_enchilada — direct pin to replica i (1..N)
#   pusher.whole_enchilada           — round-robin to all push-server replicas
#   pusher_<i>.whole_enchilada       — direct pin to replica i (1..M)
#   receiver.whole_enchilada         — example webhook consumer
#   keycloak.whole_enchilada         — Keycloak AS (two realms: tenant-a + tenant-b)
#
# Stage-2 ports exposed to host:
#   8080  → nginx (MCP / SSE)
#   8180  → Keycloak admin UI + token endpoints

networks:
  whole_enchilada:
    driver: bridge
  # mcpkit is a shared bridge network across the whole-enchilada demo
  # AND the docker/observability LGTM stack — the otel-collector listens
  # on it so the event-server / push-server can export OTLP to it by
  # container name (mcpkit-otel-collector:4317). Declared with
  # `name: mcpkit` so compose looks up the existing network by literal
  # name (no project prefix). Whichever stack starts first creates it.
  mcpkit:
    name: mcpkit
    driver: bridge

services:
  nginx:
    image: nginx:1.27-alpine
    ports:
      - "8080:80"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
    networks:
      whole_enchilada:
        aliases:
          - nginx.whole_enchilada
    depends_on:
{{range .EventServers}}      - event-server-{{.}}
{{end}}{{range .PushServers}}      - push-server-{{.}}
{{end}}      - receiver

{{range .EventServers}}
  event-server-{{.}}:
    build:
      context: ../../..
      dockerfile: examples/events/whole-enchilada/event-server/Dockerfile
    environment:
      EVENT_INJECT_BEARER: ${EVENT_INJECT_BEARER:-{{$.InjectBearer}}}
      # Stage-2: introspection-mode auth. The event-server's
      # tryEnableIntrospection reads OAUTH_INTROSPECTION_URLS as a
      # comma-separated list of N introspection endpoints and wires a
      # MultiIntrospectionValidator that accepts a token if ANY realm's
      # introspection endpoint returns active=true. Shared client_id /
      # client_secret across all realms (DEMO ONLY — production would
      # register a distinct client per realm).
      OAUTH_INTROSPECTION_URLS: http://keycloak.whole_enchilada:8080/realms/tenant-a/protocol/openid-connect/token/introspect,http://keycloak.whole_enchilada:8080/realms/tenant-b/protocol/openid-connect/token/introspect,http://keycloak.whole_enchilada:8080/realms/tenant-c/protocol/openid-connect/token/introspect
      OAUTH_CLIENT_ID: mcp-event-server
      OAUTH_CLIENT_SECRET: ${OAUTH_CLIENT_SECRET:-{{$.KCResourceSecret}}}
      OAUTH_CACHE_TTL: ${OAUTH_CACHE_TTL:-5s}
      # OTel telemetry. EXPORTER=auto means "best-effort OTLP with
      # silent Noop fallback" — works whether docker/observability is
      # up or not. To force OTLP and fail loudly when the collector
      # is missing, set EXPORTER=otlp in the host shell before
      # docker compose up.
      EXPORTER: ${EXPORTER:-auto}
      OTEL_EXPORTER_OTLP_ENDPOINT: ${OTEL_EXPORTER_OTLP_ENDPOINT:-mcpkit-otel-collector:4317}
    command: ["-addr", ":8080"]
    expose:
      - "8080"
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost:8080/healthz"]
      interval: 5s
      timeout: 2s
      retries: 5
    depends_on:
      keycloak:
        condition: service_healthy
    networks:
      whole_enchilada:
        aliases:
          - event_server.whole_enchilada
          - event_server_{{.}}.whole_enchilada
      mcpkit: {}
{{end}}
{{range .PushServers}}
  push-server-{{.}}:
    build:
      context: ../../..
      dockerfile: examples/events/whole-enchilada/push-server/Dockerfile
    environment:
      EVENT_SERVER_URL: http://event_server.whole_enchilada
      EVENT_INJECT_BEARER: ${EVENT_INJECT_BEARER:-{{$.InjectBearer}}}
      EXPORTER: ${EXPORTER:-auto}
      OTEL_EXPORTER_OTLP_ENDPOINT: ${OTEL_EXPORTER_OTLP_ENDPOINT:-mcpkit-otel-collector:4317}
    command: ["-admin-addr", ":9091", "-chat-every", "2s", "-presence-every", "5s"]
    expose:
      - "9091"
    depends_on:
{{range $.EventServers}}      event-server-{{.}}:
        condition: service_healthy
{{end}}    networks:
      whole_enchilada:
        aliases:
          - pusher.whole_enchilada
          - pusher_{{.}}.whole_enchilada
      mcpkit: {}
{{end}}
  receiver:
    build:
      context: ../../..
      dockerfile: examples/events/whole-enchilada/receiver/Dockerfile
    environment:
      WEBHOOK_SECRET: ${WEBHOOK_SECRET:-{{.WebhookSecret}}}
    command: ["-addr", ":9090", "-secret", "${WEBHOOK_SECRET:-{{.WebhookSecret}}}"]
    expose:
      - "9090"
    networks:
      whole_enchilada:
        aliases:
          - receiver.whole_enchilada

  # -------------------------------------------------------------------
  # Stage 2 — Keycloak as the OAuth AS. Two realms (tenant-a + tenant-b)
  # imported at first start from ./keycloak/realms/*.json. The admin UI
  # at localhost:8180 is the operator-facing surface for the demo's
  # revocation walkthrough step ("Sign out user" in the realm's Users
  # tab triggers a -32012 within OAUTH_CACHE_TTL).
  # -------------------------------------------------------------------
  keycloak:
    image: quay.io/keycloak/keycloak:26.0
    command: ["start-dev", "--http-port=8080", "--import-realm"]
    environment:
      KEYCLOAK_ADMIN: admin
      KEYCLOAK_ADMIN_PASSWORD: admin
      KC_HTTP_RELATIVE_PATH: /
    volumes:
      - ./keycloak/realms:/opt/keycloak/data/import:ro
    ports:
      - "8180:8080"
    healthcheck:
      # 26.x exposes a management endpoint distinct from the user endpoint;
      # /health/ready lives on port 9000 by default. We probe the realm
      # discovery doc on the user port instead, which is up once import
      # completes and tells us the realm is actually usable.
      test:
        - CMD-SHELL
        - "exec 3<>/dev/tcp/localhost/8080 && printf 'GET /realms/tenant-c/.well-known/openid-configuration HTTP/1.0\\r\\n\\r\\n' >&3 && grep -q 'HTTP/1.[01] 200' <&3"
      interval: 5s
      timeout: 5s
      retries: 30
      start_period: 30s
    networks:
      whole_enchilada:
        aliases:
          - keycloak.whole_enchilada

