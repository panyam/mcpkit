# GENERATED by tools/gen-compose. DO NOT EDIT.
# Regenerate via `make gen-compose [N=<n>] [M=<m>]` (default N=1, M=1).
#
# whole-enchilada — production-shape MCP Events demo, stage 2.
#
# DNS convention (resolves inside the compose network AND from the host
# when /etc/hosts is populated via `make hosts-install`):
#
#   nginx.whole-enchilada            — frontdoor (port 80)
#   event-server.whole-enchilada     — round-robin to all event-server replicas
#   event-server-<i>.whole-enchilada — direct pin to replica i (1..N)
#   pusher.whole-enchilada           — round-robin to all push-server replicas
#   pusher-<i>.whole-enchilada       — direct pin to replica i (1..M)
#   receiver.whole-enchilada         — example webhook consumer
#   keycloak.whole-enchilada         — Keycloak AS (two realms: tenant-a + tenant-b)
#
# Ports exposed to host:
#   9090  → nginx (MCP / SSE) — moved off 8080 to avoid conflicting with
#           ext-apps/compat fixtures that also use 8080
#   8180  → Keycloak admin UI + token endpoints

networks:
  whole-enchilada:
    driver: bridge
  # mcpkit is a shared bridge network across the whole-enchilada demo
  # AND the docker/observability LGTM stack — the otel-collector listens
  # on it so the event-server / push-server can export OTLP to it by
  # container name (mcpkit-otel-collector:4317). Declared with
  # `name: mcpkit` so compose looks up the existing network by literal
  # name (no project prefix). Whichever stack starts first creates it.
  mcpkit:
    name: mcpkit
    driver: bridge

services:
  nginx:
    image: nginx:1.27-alpine
    ports:
      - "9090:80"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
    networks:
      whole-enchilada:
        aliases:
          - nginx.whole-enchilada
    depends_on:
{{range .EventServers}}      - event-server-{{.}}
{{end}}{{range .PushServers}}      - push-server-{{.}}
{{end}}      - receiver

{{range .EventServers}}
  event-server-{{.}}:
    build:
      context: ../../..
      dockerfile: examples/events/whole-enchilada/event-server/Dockerfile
    environment:
      EVENT_INJECT_BEARER: ${EVENT_INJECT_BEARER:-{{$.InjectBearer}}}
      # Stage-2: introspection-mode auth. The event-server's
      # tryEnableIntrospection reads OAUTH_INTROSPECTION_URLS as a
      # comma-separated list of N introspection endpoints and wires a
      # MultiIntrospectionValidator that accepts a token if ANY realm's
      # introspection endpoint returns active=true. Shared client_id /
      # client_secret across all realms (DEMO ONLY — production would
      # register a distinct client per realm).
      OAUTH_INTROSPECTION_URLS: http://keycloak.whole-enchilada:8080/realms/tenant-a/protocol/openid-connect/token/introspect,http://keycloak.whole-enchilada:8080/realms/tenant-b/protocol/openid-connect/token/introspect,http://keycloak.whole-enchilada:8080/realms/tenant-c/protocol/openid-connect/token/introspect
      OAUTH_CLIENT_ID: mcp-event-server
      OAUTH_CLIENT_SECRET: ${OAUTH_CLIENT_SECRET:-{{$.KCResourceSecret}}}
      OAUTH_CACHE_TTL: ${OAUTH_CACHE_TTL:-5s}
      # OAUTH_ISSUER_BASE is the PUBLIC scheme://host:port that
      # appears in token iss claims — same value KC_HOSTNAME is set
      # to on the keycloak service below. The BCL receiver expects
      # iss = OAUTH_ISSUER_BASE + "/realms/" + <realm> exactly.
      OAUTH_ISSUER_BASE: http://localhost:8180
      # OTel telemetry. EXPORTER=auto means "best-effort OTLP with
      # silent Noop fallback" — works whether docker/observability is
      # up or not. To force OTLP and fail loudly when the collector
      # is missing, set EXPORTER=otlp in the host shell before
      # docker compose up.
      OTEL_EXPORTER_OTLP_ENDPOINT: ${OTEL_EXPORTER_OTLP_ENDPOINT:-mcpkit-otel-collector:4317}
    # `--exporter=auto` means best-effort OTLP with Noop fallback when
    # the collector is unreachable. common.RegisterTelemetryFlags
    # doesn't read EXPORTER from env, so we wire it via the CLI flag;
    # operators override with `EXPORTER=otlp make up` for fail-loud.
    command: ["-addr", ":8080", "--exporter=${EXPORTER:-auto}", "--otlp-endpoint=${OTEL_EXPORTER_OTLP_ENDPOINT:-mcpkit-otel-collector:4317}"]
    expose:
      - "8080"
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost:8080/healthz"]
      interval: 5s
      timeout: 2s
      retries: 5
    depends_on:
      keycloak:
        condition: service_healthy
    networks:
      whole-enchilada:
        aliases:
          - event-server.whole-enchilada
          - event-server-{{.}}.whole-enchilada
      mcpkit: {}
{{end}}
{{range .PushServers}}
  push-server-{{.}}:
    build:
      context: ../../..
      dockerfile: examples/events/whole-enchilada/push-server/Dockerfile
    environment:
      EVENT_SERVER_URL: http://event-server.whole-enchilada:8080
      EVENT_INJECT_BEARER: ${EVENT_INJECT_BEARER:-{{$.InjectBearer}}}
      OTEL_EXPORTER_OTLP_ENDPOINT: ${OTEL_EXPORTER_OTLP_ENDPOINT:-mcpkit-otel-collector:4317}
    command: ["-admin-addr", ":9091", "-chat-every", "2s", "-presence-every", "5s", "--exporter=${EXPORTER:-auto}", "--otlp-endpoint=${OTEL_EXPORTER_OTLP_ENDPOINT:-mcpkit-otel-collector:4317}"]
    expose:
      - "9091"
    depends_on:
{{range $.EventServers}}      event-server-{{.}}:
        condition: service_healthy
{{end}}    networks:
      whole-enchilada:
        aliases:
          - pusher.whole-enchilada
          - pusher-{{.}}.whole-enchilada
      mcpkit: {}
{{end}}
  receiver:
    build:
      context: ../../..
      dockerfile: examples/events/whole-enchilada/receiver/Dockerfile
    environment:
      WEBHOOK_SECRET: ${WEBHOOK_SECRET:-{{.WebhookSecret}}}
    command: ["-addr", ":9090", "-secret", "${WEBHOOK_SECRET:-{{.WebhookSecret}}}"]
    expose:
      - "9090"
    networks:
      whole-enchilada:
        aliases:
          - receiver.whole-enchilada

  # -------------------------------------------------------------------
  # Stage 2 — Keycloak as the OAuth AS. Two realms (tenant-a + tenant-b)
  # imported at first start from ./keycloak/realms/*.json. The admin UI
  # at localhost:8180 is the operator-facing surface for the demo's
  # revocation walkthrough step ("Sign out user" in the realm's Users
  # tab triggers a -32012 within OAUTH_CACHE_TTL).
  # -------------------------------------------------------------------
  keycloak:
    image: quay.io/keycloak/keycloak:26.0
    command: ["start-dev", "--http-port=8080", "--import-realm"]
    environment:
      KEYCLOAK_ADMIN: admin
      KEYCLOAK_ADMIN_PASSWORD: admin
      KC_HTTP_RELATIVE_PATH: /
      # Tell Keycloak its public hostname so HostnameV2Provider has a
      # deterministic URI source. Without this, Keycloak 26 NPEs on
      # any request that arrives without a Host header (e.g., raw-TCP
      # healthchecks) because HostnameV2Provider.getFrontUriBuilder
      # falls back to request.authority() which is null on HTTP/1.0
      # probes. Setting KC_HOSTNAME makes the realm discovery URLs
      # absolute against this value too — fine for the demo since the
      # operator hits the admin UI at localhost:8180.
      KC_HOSTNAME: http://localhost:8180
      KC_HOSTNAME_STRICT: "false"
    volumes:
      - ./keycloak/realms:/opt/keycloak/data/import:ro
    ports:
      - "8180:8080"
    healthcheck:
      # Probe realm-c's discovery doc — the last realm imported alphabetically,
      # so seeing it 200-OK means all three realms are live. HTTP/1.1 with
      # explicit Host header so HostnameV2Provider has what it needs.
      test:
        - CMD-SHELL
        - "exec 3<>/dev/tcp/localhost/8080 && printf 'GET /realms/tenant-c/.well-known/openid-configuration HTTP/1.1\\r\\nHost: localhost\\r\\nConnection: close\\r\\n\\r\\n' >&3 && head -c 64 <&3 | grep -q '200 OK'"
      interval: 5s
      timeout: 5s
      retries: 30
      start_period: 30s
    networks:
      whole-enchilada:
        aliases:
          - keycloak.whole-enchilada

  # One-shot sidecar that flips the BUILT-IN master realm's sslRequired
  # to NONE. The tenant-{a,b,c} realm JSONs we import already set
  # sslRequired=none, but the master realm (which backs /admin/console
  # for the operator's revocation walkthrough) is created by Keycloak
  # itself and can't be overridden via realm-import — kcadm.sh is the
  # only documented path. Without this, hitting http://localhost:8180/
  # in some browsers force-upgrades to HTTPS or shows "HTTPS required"
  # on certain admin routes. Runs once after keycloak is healthy, then
  # exits.
  keycloak-init:
    image: quay.io/keycloak/keycloak:26.0
    depends_on:
      keycloak:
        condition: service_healthy
    entrypoint: ["/bin/bash", "-c"]
    command:
      - >
        /opt/keycloak/bin/kcadm.sh config credentials
        --server http://keycloak:8080
        --realm master --user admin --password admin
        && /opt/keycloak/bin/kcadm.sh update realms/master -s sslRequired=NONE
        && echo "[keycloak-init] master realm sslRequired=NONE"
    restart: "no"
    networks:
      whole-enchilada:
        aliases:
          - keycloak-init.whole-enchilada

