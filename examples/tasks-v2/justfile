MODEL := env('MODEL', '')
BASE_URL := env('BASE_URL', '')

# Run the scripted agent scenario (no LLM): an agent drives the task tools through chat
agent:
	go run . --agent

# Run the agent scenario against a live model (MODEL=<name> [BASE_URL=<url>])
agent-live:
	go run . --agent --model {{MODEL}} {{if BASE_URL != '' { '--base-url ' + BASE_URL } else { '' }}}

# Run the agent golden-transcript test
agent-test:
	go test ./... -count=1 -run TestAgentScenario

# Run the demokit walkthrough (interactive, TUI)
demo:
	go run . --tui

# Run the walkthrough in notebook mode (Bubble Tea cells)
note:
	go run . --note

# Start the v2 tasks server standalone (for MCPJam, VS Code, Claude Desktop)
serve:
	go run . --serve

# Regenerate WALKTHROUGH.md from demo definitions
readme:
	go run . --doc md > WALKTHROUGH.md

# Build the binary
build:
	go build -o tasks-v2-demo .
