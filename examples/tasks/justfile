# Run the demokit walkthrough (interactive, TUI)
demo:
	go run . --tui

# Run the walkthrough in notebook mode (Bubble Tea cells)
note:
	go run . --note

# Start the tasks MCP server standalone (for MCPJam, VS Code, Claude Desktop)
serve:
	go run . --serve

# Regenerate WALKTHROUGH.md from demo definitions
readme:
	go run . --doc md > WALKTHROUGH.md

# Run the TS reference server (parity check)
runts:
	node ts-reference-server.mjs

# Build the binary
build:
	go build -o tasks-demo .
