# Start the skills-core server (file mode, :8080)
serve:
    go run . --serve

# Run the walkthrough in interactive TUI. Server must be up via `just serve` in another terminal.
demo:
    go run . --tui

# Run the walkthrough (plain, non-interactive-friendly).
run:
    go run .

# Run the walkthrough in notebook mode (Bubble Tea cells).
note:
    go run . --note

# Regenerate WALKTHROUGH.md from the demo definitions.
readme:
    go run . --doc=md > WALKTHROUGH.md

# Build the binary to ./skills-core
build:
    go build -o skills-core .

default: serve
