# Run the demokit walkthrough (interactive, TUI)
demo:
    go run . --tui

# Run the walkthrough in notebook mode (Bubble Tea cells)
note:
    go run . --note

# Start the list-ttl demo server (default :8080, ttl-ms=60000)
serve:
    go run . --serve --ttl-ms=60000

# Regenerate WALKTHROUGH.md from demo definitions
readme:
    go run . --doc md > WALKTHROUGH.md

# Build the binary
build:
    go build -o list-ttl-demo .

default: demo
