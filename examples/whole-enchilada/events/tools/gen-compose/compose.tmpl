# GENERATED by tools/gen-compose. DO NOT EDIT.
# Regenerate via `make gen-compose [N=<n>] [M=<m>]` (default N=1, M=1).
#
# whole-enchilada / events — production-shape MCP Events demo, stage 2.
#
# This compose owns ONLY the events-specific services (nginx, event-
# server replicas, webhook receiver). The shared infra (Keycloak,
# Postgres, Redis, LGTM observability) lives in sibling composes under
# ./docker/ and bridges via the literal `mcpkit` docker network.
# Bring them up first:
#
#   cd ../../../docker/backends && make up
#   cd ../../../docker/observability && make up    # optional
#
# `make up` here chains those automatically.
#
# DNS convention (resolves inside the compose network AND from the host
# when /etc/hosts is populated via `make hosts-install`):
#
#   nginx.whole-enchilada            — frontdoor (port 80)
#   event-server.whole-enchilada     — round-robin to all event-server replicas
#   event-server-<i>.whole-enchilada — direct pin to replica i (1..N)
#   receiver.whole-enchilada         — example webhook consumer
#
# Synthetic producers (chat / presence) ran in an in-compose push-server
# tier in earlier revisions; they're now operator-runnable host drivers
# under drivers/synth/ (one binary, vocab selected via --event). `make
# drive-chat` and `make drive-presence` from sibling terminals start
# them — stack comes up silent until the operator fires a driver.
# push-server source code stays in push-server/ as a reference for the
# production-shape HTTPSource pattern.
#
# Shared infra (on the `mcpkit` network — bare aliases):
#
#   keycloak                         — Keycloak AS (3 tenant realms) — docker/backends
#   postgres                         — Postgres 18 — docker/backends
#   redis                            — Redis 7 — docker/backends
#   mcpkit-otel-collector            — OTLP collector — docker/observability
#
# Ports exposed to host:
#   9090  → nginx (MCP / SSE) — moved off 8080 to avoid conflicting with
#           ext-apps/compat fixtures that also use 8080

networks:
  whole-enchilada:
    driver: bridge
  # mcpkit is the literal-name shared bridge so this compose can reach
  # the docker/backends services (keycloak, postgres, redis) and the
  # docker/observability collector by container/alias. `name: mcpkit`
  # keeps the network's docker-side name literal — no project prefix —
  # so cross-compose lookups resolve without surprises. Whichever stack
  # starts first creates it.
  mcpkit:
    name: mcpkit
    driver: bridge

services:
  nginx:
    image: nginx:1.27-alpine
    ports:
      - "9090:80"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
    networks:
      whole-enchilada:
        aliases:
          - nginx.whole-enchilada
    depends_on:
{{range .EventServers}}      - event-server-{{.}}
{{end}}      - receiver

{{range .EventServers}}
  event-server-{{.}}:
    build:
      context: ../../..
      dockerfile: examples/whole-enchilada/events/event-server/Dockerfile
    # Lets the event-server reach webhook receivers running on the
    # host (e.g. `make webhook` opens a listener on the operator's
    # 127.0.0.1:<dynamic-port>). Docker Desktop on macOS/Windows
    # auto-maps host.docker.internal; Linux needs the explicit
    # host-gateway entry. The webhook binary rewrites its callback
    # URL from 127.0.0.1 → host.docker.internal so this entry is
    # what makes that URL resolvable from inside the container.
    extra_hosts:
      - "host.docker.internal:host-gateway"
    environment:
      # Stamped on every HTTP response (X-Replica header) and every
      # outbound webhook POST so the multi-replica walkthrough beat
      # can show round-robin rotation + which replica fanned out each
      # webhook. Falls back to os.Hostname() if unset, but compose's
      # default short-hash hostname isn't operator-readable — set
      # explicitly per replica.
      REPLICA_NAME: event-server-{{.}}
      EVENT_INJECT_BEARER: ${EVENT_INJECT_BEARER:-{{$.InjectBearer}}}
      # Stage-2: introspection-mode auth. The event-server's
      # tryEnableIntrospection reads OAUTH_INTROSPECTION_URLS as a
      # comma-separated list of N introspection endpoints and wires a
      # MultiIntrospectionValidator that accepts a token if ANY realm's
      # introspection endpoint returns active=true. Shared client_id /
      # client_secret across all realms (DEMO ONLY — production would
      # register a distinct client per realm).
      OAUTH_INTROSPECTION_URLS: http://keycloak:8080/realms/asgard/protocol/openid-connect/token/introspect,http://keycloak:8080/realms/babylon/protocol/openid-connect/token/introspect,http://keycloak:8080/realms/camelot/protocol/openid-connect/token/introspect
      OAUTH_CLIENT_ID: mcp-event-server
      OAUTH_CLIENT_SECRET: ${OAUTH_CLIENT_SECRET:-{{$.KCResourceSecret}}}
      OAUTH_CACHE_TTL: ${OAUTH_CACHE_TTL:-5s}
      # OAUTH_ISSUER_BASE is the PUBLIC scheme://host:port that
      # appears in token iss claims — same value KC_HOSTNAME is set
      # to on the keycloak service in docker/backends. The BCL
      # receiver expects iss = OAUTH_ISSUER_BASE + "/realms/" + <realm>
      # exactly.
      OAUTH_ISSUER_BASE: http://localhost:8180
      # OTel telemetry. EXPORTER=auto means "best-effort OTLP with
      # silent Noop fallback" — works whether docker/observability is
      # up or not. To force OTLP and fail loudly when the collector
      # is missing, set EXPORTER=otlp in the host shell before
      # docker compose up.
      OTEL_EXPORTER_OTLP_ENDPOINT: ${OTEL_EXPORTER_OTLP_ENDPOINT:-mcpkit-otel-collector:4317}
      # Redis backend (issues 634 + 718). When REDIS_ADDR is set,
      # event-server's configureRedisBackend swaps the in-memory
      # QuotaStore + LocalEmitter defaults for Redis-backed
      # counterparts (Pattern B: Publisher is the sole outbound sink;
      # Subscriber delivers to LOCAL on every replica). This is what
      # makes the multi-replica push-survival demo actually work —
      # without it, each replica maintains its own subscription
      # counts and fans out only locally. Resolves to docker/backends
      # via the shared mcpkit network.
      REDIS_ADDR: ${REDIS_ADDR:-redis:6379}
      # Postgres backend (issue 639). When POSTGRES_DSN is set,
      # event-server's configurePostgresBackend swaps the in-memory
      # WebhookStore default for the gorm-backed Postgres impl —
      # webhook subscriptions survive replica restarts and live in a
      # single source of truth across replicas. Resolves to
      # docker/backends via the shared mcpkit network.
      POSTGRES_DSN: ${POSTGRES_DSN:-postgres://postgres:postgres@postgres:5432/events?sslmode=disable}
      # Per-event-type subscription caps. Format:
      # EVENTS_QUOTA_CAPS=<eventName>=<int>[,<eventName>=<int>...]
      # When set, event-server constructs Quota with
      # WithMaxSubscriptionsPerPrincipal(name, n) per entry. Cross-
      # replica enforcement comes from the Redis-backed QuotaStore
      # (issue 718); a 4th subscribe for the same principal lands on
      # any replica → -32013 ResourceExhausted with the
      # {limit:"subscriptions", max:N} envelope.
      # Default chat.message=10 gives operating headroom for normal
      # demo play (3 streamers + 3 webhooks + some accumulated Ctrl+C
      # remnants stay well under cap). The Phase 6 walkthrough beat
      # overrides this down to 3 via EVENTS_QUOTA_CAPS=chat.message=3
      # for its "subscribe 4 times, watch the 4th fail" demonstration.
      EVENTS_QUOTA_CAPS: ${EVENTS_QUOTA_CAPS:-chat.message=10}
      # EVENTS_ALLOW_INFINITE_TTL=true opts the registry into accepting
      # `ttlMs: null` requests + returning `refreshBefore: null` (PR 779,
      # spec PR1 commit 99f3589c §"Subscription TTL"). Default ON in
      # this demo so the TTL-negotiation + no-expiry walkthrough beats
      # work out of the box. Production deployments leave this OFF
      # unless they've also wired a durable WebhookStore (we have —
      # POSTGRES_DSN above) AND accepted the failure-based GC obligations.
      EVENTS_ALLOW_INFINITE_TTL: ${EVENTS_ALLOW_INFINITE_TTL:-true}
      # EVENTS_NO_EXPIRY_GC_WINDOW tightens the failure-based GC clock
      # for no-expiry subscriptions (PR 783). Library default is 72h
      # (DefaultNoExpiryFailureGCWindow) — invisible in a 30-min demo;
      # 2m makes the end-to-end "subscriber dies, server drops the no-
      # expiry sub after sustained delivery failure" beat observable.
      # Production deployments leave this at the default (or longer).
      EVENTS_NO_EXPIRY_GC_WINDOW: ${EVENTS_NO_EXPIRY_GC_WINDOW:-2m}
      # POSTGRES_BUFFER_TTL — retention window for Postgres-backed
      # EventBufferStore rows (issue 727). The background sweeper drops
      # rows past expires_at every 60s; clients polling for an evicted
      # cursor get truncated:true back. 10m for the demo so the
      # "stale cursor truncates" walkthrough beat doesn't need an hour
      # of patience.
      POSTGRES_BUFFER_TTL: ${POSTGRES_BUFFER_TTL:-10m}
    # `--exporter=auto` means best-effort OTLP with Noop fallback when
    # the collector is unreachable. common.RegisterTelemetryFlags
    # doesn't read EXPORTER from env, so we wire it via the CLI flag;
    # operators override with `EXPORTER=otlp make up` for fail-loud.
    command: ["-addr", ":8080", "--exporter=${EXPORTER:-auto}", "--otlp-endpoint=${OTEL_EXPORTER_OTLP_ENDPOINT:-mcpkit-otel-collector:4317}"]
    expose:
      - "8080"
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost:8080/healthz"]
      interval: 5s
      timeout: 2s
      retries: 5
    # No cross-compose depends_on for keycloak / postgres / redis —
    # those live in docker/backends/ as a separate compose project.
    # `make up` brings backends up first; once running, the Go client
    # retry loops inside event-server tolerate brief unavailability
    # during boot.
    networks:
      whole-enchilada:
        aliases:
          - event-server.whole-enchilada
          - event-server-{{.}}.whole-enchilada
      mcpkit: {}
{{end}}
  receiver:
    build:
      context: ../../..
      dockerfile: examples/whole-enchilada/events/receiver/Dockerfile
    environment:
      WEBHOOK_SECRET: ${WEBHOOK_SECRET:-{{.WebhookSecret}}}
    command: ["-addr", ":9090", "-secret", "${WEBHOOK_SECRET:-{{.WebhookSecret}}}"]
    expose:
      - "9090"
    networks:
      whole-enchilada:
        aliases:
          - receiver.whole-enchilada
