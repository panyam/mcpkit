# Sign out every USER session in all 3 tenant realms (keeps mcp-event-server client creds intact).
clear_all_tokens:
	#!/usr/bin/env bash
	set -eu
	docker exec mcpkit-keycloak /opt/keycloak/bin/kcadm.sh config credentials \
		--server http://keycloak:8080 --realm master --user admin --password admin >/dev/null
	for realm in asgard babylon camelot; do
		docker exec mcpkit-keycloak /opt/keycloak/bin/kcadm.sh create logout-all -r $realm >/dev/null && \
		echo "[clear_all_tokens] $realm: all user sessions signed out"
	done

# Quick clean slate without a full predemo: sign out Keycloak sessions + delete Redis quota keys + truncate webhooks. Survivors of Ctrl+C from prior demo runs (counters/subs that didn't release cleanly) get wiped so the cap=3 quota resets and stale callback URLs disappear. Heavier hammer if needed: stop the stack and `rm -rf ../../../docker/backends/data/redis`.
clear-all: clear_all_tokens
	#!/usr/bin/env bash
	set -eu
	deleted=$(docker exec mcpkit-redis sh -c 'redis-cli --scan --pattern "mcpkit.events.quota.*" | xargs -r redis-cli DEL' 2>/dev/null || echo 0)
	echo "[clear-all] redis quota keys deleted: $deleted"
	docker exec mcpkit-postgres psql -U postgres -d events -c "TRUNCATE TABLE webhooks" >/dev/null 2>&1 && \
		echo "[clear-all] webhooks table truncated" || \
		echo "[clear-all] webhooks table not present yet (no subs ever created) — skip"

# Inject one event from the host. TENANT=A|B|C [EVENT=chat.message] [TEXT="..."].
inject:
	#!/usr/bin/env bash
	set -eu
	if [ -z "{{TENANT}}" ]; then echo "usage: TENANT=A|B|C [EVENT=<name>] [TEXT='...'] just inject"; exit 2; fi
	go -C inject run . --tenant {{tenant_realm}} --event {{EVENT}} --text '{{TEXT}}'

# Tail logs from all services.
logs:
	docker compose logs -f --tail=200

# docker compose ps.
ps:
	docker compose ps

# Print the webhooks table from Postgres — used by the no-expiry restart-survival beat to confirm rows survive a `just restart-event-servers`.
psql-webhooks:
	docker compose -f {{BACKENDS_COMPOSE}} exec -T postgres \
		psql -U postgres -d events \
		-c "SELECT id, principal, url, expires_at, status_failing_continuously_since FROM webhooks ORDER BY principal;"

# Rolling-restart the event-server replicas. Used by the no-expiry restart-survival beat — finite subs and no-expiry subs both survive (rows stay in Postgres), proving the GORM-backed WebhookStore is the durability backbone. Replica set is discovered from compose, so it tracks whatever N the stack was generated with.
restart-event-servers:
	#!/usr/bin/env bash
	set -eu
	svcs=$(docker compose config --services | grep '^event-server-')
	echo "[restart-event-servers] restarting: $svcs"
	docker compose restart $svcs
	docker compose up -d --wait $svcs

# docker compose down -v on the events stack + remove built binaries. Backends data is preserved — use `just clean-backends` for a full reset.
clean:
	docker compose down -v 2>/dev/null || true
	rm -rf bin/

# Tear down backends AND wipe their persisted data (postgres + redis bind mounts). Use after schema changes or when starting fresh.
clean-backends:
	docker compose -f {{BACKENDS_COMPOSE}} down -v 2>/dev/null || true
	rm -rf ../../../docker/backends/data/

# Append *.whole-enchilada hostnames to /etc/hosts (idempotent).
hosts-install:
	#!/usr/bin/env bash
	set -eu
	if grep -q "whole-enchilada hostnames" /etc/hosts; then
		echo "[hosts] already installed; run hosts-uninstall first to refresh"
	else
		sudo sh -c 'printf "\n# whole-enchilada hostnames — managed by make hosts-install\n127.0.0.1 {{HOSTS_NAMES}}\n" >> /etc/hosts'
		echo "[hosts] installed: {{HOSTS_NAMES}}"
	fi

# Remove the whole-enchilada /etc/hosts entries.
hosts-uninstall:
	@sudo sed -i.bak '/whole-enchilada hostnames/,+1 d' /etc/hosts && rm -f /etc/hosts.bak
	@echo "[hosts] uninstalled"
