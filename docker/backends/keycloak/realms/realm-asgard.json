{
  "realm": "asgard",
  "displayName": "Asgard",
  "enabled": true,
  "sslRequired": "none",
  "defaultSignatureAlgorithm": "RS256",
  "accessTokenLifespan": 1800,
  "ssoSessionIdleTimeout": 3600,
  "ssoSessionMaxLifespan": 7200,
  "clients": [
    {
      "clientId": "mcp-event-server",
      "name": "MCP Event-Server (introspection client; called by the resource server when validating bearer tokens)",
      "description": "DEMO ONLY \u2014 rotate this secret in any non-demo deployment.",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "mcpkit-demo-secret-DEMO-ONLY",
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "openid"
      ]
    },
    {
      "clientId": "mcp-events-poller",
      "name": "MCP Events Poller (demo client used by `make poller TENANT=A`)",
      "description": "DEMO ONLY \u2014 pre-baked secret for the demo poller. Real deployments register a unique client per consumer.",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "mcpkit-demo-secret-DEMO-ONLY",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:*",
        "http://127.0.0.1:*"
      ],
      "webOrigins": [
        "*"
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "backchannel.logout.url": "http://event-server.whole-enchilada:8080/backchannel-logout/asgard",
        "backchannel.logout.session.required": "true",
        "backchannel.logout.revoke.offline.tokens": "false"
      },
      "protocolMappers": [
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "introspection.token.claim": "true",
            "userinfo.token.claim": "true",
            "user.attribute": "id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "sub",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "mcp-events-webhook",
      "name": "MCP Events Webhook (demo client used by `make webhook TENANT=A`)",
      "description": "DEMO ONLY \u2014 pre-baked secret for the demo webhook receiver.",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "mcpkit-demo-secret-DEMO-ONLY",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:*",
        "http://127.0.0.1:*"
      ],
      "webOrigins": [
        "*"
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
