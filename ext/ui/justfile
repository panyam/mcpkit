# ext/ui justfile — recipe bodies live in ext/ui/scripts/*.sh (runner-agnostic,
# shared with the Makefile).

# Run Go + JS bridge unit tests
test:
    @bash scripts/test.sh

# Run JS bridge unit tests (requires pnpm + Node.js)
test-bridge:
    @bash scripts/test-bridge.sh

# Run Playwright bridge integration tests (requires Chromium)
test-bridge-e2e:
    @bash scripts/test-bridge-e2e.sh

# Compile mcp-app-bridge.ts → .js (requires pnpm + TypeScript)
build-bridge:
    @bash scripts/build-bridge.sh
