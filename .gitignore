examples/mrtr/mrtr
examples/tasks/tasks
examples/tasks-v2/tasks-v2

# Make build artifacts (Makefile `build` target → <name>-demo or
# <name>-example). Globs catch every example's named output.
examples/**/*-demo
examples/**/*-example
