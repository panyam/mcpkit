.DS_Store
Thumbs.db
/testserver
/testclient
cmd/testclient/testclient
cmd/testserver/testserver
docs/COMPETITIVE_ANALYSIS.md

# Example binaries (go build . produces a binary matching the dir name).
# Each Makefile's build target writes a *-demo or *-example variant; the
# bare-name binaries appear when someone runs `go build .` directly.
examples/apps/htmx/htmx
examples/apps/dashboard/dashboard
examples/apps/interactive/interactive
examples/apps/react/server/server
examples/apps/todolist/todolist
examples/apps/vanilla/vanilla
examples/auth/auth
examples/auth/bearer/bearer
examples/auth/jwt/jwt
examples/auth/scopes/scopes
examples/auth/session-binding/session-binding
examples/auth/public-discovery/public-discovery
examples/auth/unified/unified
examples/elicitation/elicitation
examples/events/discord/discord
examples/events/telegram/telegram
examples/file-inputs/file-inputs
examples/fine-grained-auth/fine-grained-auth
examples/host/01-apphost/01-apphost
examples/host/02-multi-server/02-multi-server
examples/list-ttl/list-ttl
examples/mrtr/mrtr
examples/tasks/tasks
examples/tasks-v2/tasks-v2

# Make build artifacts (Makefile `build` target → <name>-demo or
# <name>-example). Globs catch every example's named output.
examples/**/*-demo
examples/**/*-example

# apps/compat Playwright run artifacts (actual / diff PNGs, traces, HTML
# report). Written to .test-results/ next to each fixture's __snapshots__/
# dir by apps-playwright-test.sh. Per-run; never committed.
examples/apps/compat/*/.test-results/

# apps/compat docker-mode cross-compiled fixture binaries — host-side
# scratch only, the docker run mounts them into the container.
.tmp-fixture-linux-amd64-*
/discord_tracking

# cmd + docs-site tool binaries (`go build .` output).
cmd/mcpskills/mcpskills
docs/site/site

# apps/compat fixture binaries. `go build .` produces a bare dir-name
# binary; each fixture's local .gitignore only covered the `-demo`
