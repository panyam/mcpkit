{{- define "elicitHelpers" -}}
{{- range .Elicitations }}
// {{ .GoHelper }} sends a typed elicitation request using the schema derived
// from {{ .SchemaType }}. Returns the populated proto message, the user's action
// ("accept"/"decline"/"cancel"), and any error.
// If the user does not accept, the returned message pointer is nil.
func {{ .GoHelper }}(ctx mcpcore.ToolContext, message string) (*{{ .SchemaType }}, string, error) {
	result, err := ctx.Elicit(mcpcore.ElicitationRequest{
		Message:         message,
		RequestedSchema: json.RawMessage(`{{ .SchemaJSON }}`),
	})
	if err != nil {
		return nil, "", err
	}
	if result.Action != "accept" {
		return nil, result.Action, nil
	}
	out, err := runtime.BindElicitResult[{{ .SchemaType }}](result.Content)
	if err != nil {
		return nil, "", err
	}
	return out, result.Action, nil
}
{{- end }}
{{ end }}

{{- define "samplingHelpers" -}}
{{- range .Samplings }}
// {{ .GoHelper }} sends a pre-configured sampling request for {{ .ToolMethodName }}.
// Caller provides the user messages; system prompt and model preferences come
// from the mcp_sampling annotation.
func {{ .GoHelper }}(ctx mcpcore.ToolContext, messages []mcpcore.SamplingMessage) (mcpcore.CreateMessageResult, error) {
	return ctx.Sample(mcpcore.CreateMessageRequest{
		Messages:       messages,
		{{- if .SystemPrompt }}
		SystemPrompt:   "{{ .SystemPrompt }}",
		{{- end }}
		{{- if .MaxTokens }}
		MaxTokens:      {{ .MaxTokens }},
		{{- end }}
		{{- if .IncludeContext }}
		IncludeContext:  "{{ .IncludeContext }}",
		{{- end }}
		{{- if or .IntelligencePriority .SpeedPriority .CostPriority }}
		ModelPreferences: &mcpcore.ModelPreferences{
			{{- if .IntelligencePriority }}
			IntelligencePriority: floatPtr({{ .IntelligencePriority }}),
			{{- end }}
			{{- if .SpeedPriority }}
			SpeedPriority: floatPtr({{ .SpeedPriority }}),
			{{- end }}
			{{- if .CostPriority }}
			CostPriority: floatPtr({{ .CostPriority }}),
			{{- end }}
		},
		{{- end }}
	})
}
{{- end }}
