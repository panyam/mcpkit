# ext/protogen justfile

# Build the protoc plugin
build:
    @bash scripts/build.sh

# Run unit tests
test:
    @bash scripts/test.sh

# Install plugin, regenerate examples, compile, and run e2e tests
test-e2e:
    @bash scripts/test-e2e.sh

# Install the protoc plugin to $GOPATH/bin
install:
    @bash scripts/install.sh

# Lint proto files with buf
lint:
    buf lint

# Generate Go code from proto files
generate:
    buf generate

# Push proto module to buf.build/mcpkit/protogen
push:
    buf push

# Check for breaking changes against buf.build
breaking:
    buf breaking --against buf.build/mcpkit/protogen

# Update buf dependencies
dep-update:
    buf dep update

# Show this help
help:
    @just --list
