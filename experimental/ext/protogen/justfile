# ext/protogen justfile

# Build the protoc plugin
build:
    go build -o bin/protoc-gen-go-mcp ./cmd/protoc-gen-go-mcp

# Run unit tests
test:
    go test ./... -count=1 -timeout 30s

# Regenerate examples, compile, and run e2e tests
test-e2e: install
    @echo "==> e2e: bookservice example"
    cd ../../../examples/protogen/bookservice && rm -rf gen && buf generate && go test -count=1 -timeout 30s .
    @echo "==> e2e: passed"

# Install the protoc plugin to $GOPATH/bin
install: build
    go install ./cmd/protoc-gen-go-mcp

# Lint proto files with buf
lint:
    buf lint

# Generate Go code from proto files
generate:
    buf generate

# Push proto module to buf.build/mcpkit/protogen
push:
    buf push

# Check for breaking changes against buf.build
breaking:
    buf breaking --against buf.build/mcpkit/protogen

# Update buf dependencies
dep-update:
    buf dep update

# Show this help
help:
    @just --list
